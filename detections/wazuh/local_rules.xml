<!-- Local rules for STAR Banking SOC project -->
<!-- All custom rules use IDs in the 100000-110000 range -->

<group name="banking_threats,brute_force,authentication,">

  <!-- STAR-001: Banking-tuned SSH brute force detection -->
  <!-- Triggers on 5+ failed SSH logins from same source IP in 60s -->
  <!-- More sensitive than default rule 5712 (8 attempts) -->
  <rule id="100100" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>STAR: Banking SSH brute force — 5+ failed SSH logins from $(srcip) in 60s</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>banking_threats,brute_force,authentication_failures,</group>
  </rule>

</group>
