<!-- Local rules for STAR Banking SOC project -->
<!-- All custom rules use IDs in the 100000-110000 range -->

<!-- ============================================================ -->
<!-- STAR-001: Banking SSH brute force                            -->
<!-- ============================================================ -->
<group name="banking_threats,brute_force,authentication,">

  <!-- Triggers on 5+ failed SSH logins from same source IP in 60s -->
  <!-- More sensitive than default rule 5712 (8 attempts)          -->
  <rule id="100100" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>STAR: Banking SSH brute force — 5+ failed SSH logins from $(srcip) in 60s</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>banking_threats,brute_force,authentication_failures,</group>
  </rule>

</group>

<!-- ============================================================ -->
<!-- STAR-002: Banking SSH credential stuffing / user enumeration -->
<!-- ============================================================ -->
<group name="banking_threats,credential_stuffing,authentication,">

  <!-- Triggers on 3+ invalid user login attempts from same IP in 60s -->
  <!-- Catches attackers enumerating usernames or replaying leaked     -->
  <!-- credential dumps against banking infrastructure                 -->
  <rule id="100200" level="10" frequency="3" timeframe="60">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>STAR: Banking SSH credential stuffing — 3+ invalid user attempts from $(srcip) in 60s</description>
    <mitre>
      <id>T1110.004</id>
    </mitre>
    <group>banking_threats,credential_stuffing,user_enumeration,</group>
  </rule>

</group>

<!-- ============================================================ -->
<!-- STAR-003: Banking web application login brute force          -->
<!-- ============================================================ -->
<group name="banking_threats,web_brute_force,authentication,">

  <!-- Atomic: Chain off Wazuh rule 31101 (web 4xx) for /rest/user/login -->
  <rule id="100310" level="3">
    <if_sid>31101</if_sid>
    <url>/rest/user/login</url>
    <description>STAR: Failed login attempt at banking login endpoint</description>
    <group>banking_threats,web_authentication_failed,</group>
  </rule>

  <!-- Correlation: 5+ failed logins from same source IP in 60s -->
  <rule id="100300" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100310</if_matched_sid>
    <same_source_ip />
    <description>STAR: Banking web login brute force — 5+ failed login attempts at /rest/user/login from $(srcip) in 60s</description>
    <mitre><id>T1110.001</id></mitre>
    <group>banking_threats,web_brute_force,authentication_failures,</group>
  </rule>

</group>
